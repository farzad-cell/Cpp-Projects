#include <iostream>
using namespace std;

//function prototype
void printOdd(int list[], int size);
int findLowest(int list[], int size);

int main()
{
	// Part 1

	const int SIZE = 8;

	// First Array
	int arr[SIZE] = {34, 45, 66, 33, 12, 77, 5, 18};

	// Part 2 

	const int ROWS = 4;
	const int COLS = 5;

	cout << "______________Array 2______________" << endl << endl;
	// Second array
	int scores[ROWS][COLS] = {{34, 45, 66, 33, 12},
                        	  {11, 34, 67, 77, 5},
                        	  {21, 56, 31, 88, 18},
                        	  {45, 21, 19, 29, 32}};

	int count{};

	for(int i{}; i < ROWS; ++i) {
		int sumRow = 0;
		for(int j{}; j < COLS; ++j) {

			sumRow += scores[i][j];
		}

		count++;
		cout<< "Total row " << count << ": " << sumRow << endl;
		cout<<endl;
	}
	cout << "______________Array 1______________" << endl << endl;
	printOdd(arr, SIZE);

	int lowest;
	lowest = findLowest(arr, SIZE);
	cout << "\n\nLowest is " << lowest;

	return 0;
}
// Part 1
void printOdd(int list[], int size) {

	cout<<"All odd numbers: ";

	for(int i{}; i < size; ++i) {

		if(list[i] % 2 != 0) {
			cout << list[i] <<" ";
		}
	}
}
// Part 1
int findLowest(int list[], int size) {
	int low = list[0];

	for(int i{1}; i<size; ++i) {

		if(list[i] < low)
			low = list[i];
	}
	return low;
}
